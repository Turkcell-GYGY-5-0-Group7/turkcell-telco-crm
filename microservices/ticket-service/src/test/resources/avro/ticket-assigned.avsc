{
  "type": "record",
  "name": "TicketAssignedEvent",
  "namespace": "com.telco.platform.events.ticket",
  "doc": "Frozen contract snapshot for ticket.assigned.v1 (ADR-019). Producer: ticket-service; consumer: notification. Field names must match the outbox payload emitted by OpenTicketCommandHandler and AssignTicketCommandHandler; the capture-based contract test fails the build on any drift (NFR-16).",
  "fields": [
    { "name": "ticketId", "type": "string", "doc": "Unique ticket identifier (UUID)." },
    { "name": "customerId", "type": "string", "doc": "Identifier of the customer (UUID)." },
    { "name": "assignedTeam", "type": "string", "doc": "Team the ticket is assigned to." }
  ]
}
