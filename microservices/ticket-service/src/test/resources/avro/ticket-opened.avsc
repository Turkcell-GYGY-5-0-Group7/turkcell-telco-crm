{
  "type": "record",
  "name": "TicketOpenedEvent",
  "namespace": "com.telco.platform.events.ticket",
  "doc": "Frozen contract snapshot for ticket.opened.v1 (ADR-019). Producer: ticket-service; consumer: notification. Field names must match the outbox payload emitted by OpenTicketCommandHandler; the capture-based contract test fails the build on any drift (NFR-16).",
  "fields": [
    { "name": "ticketId", "type": "string", "doc": "Unique ticket identifier (UUID)." },
    { "name": "customerId", "type": "string", "doc": "Identifier of the customer (UUID)." },
    { "name": "category", "type": "string", "doc": "Ticket category." },
    { "name": "priority", "type": "string", "doc": "Ticket priority." },
    { "name": "subject", "type": "string", "doc": "Ticket subject line." },
    { "name": "assignedTeam", "type": "string", "doc": "Team the ticket is routed to." },
    { "name": "slaDueAt", "type": "string", "doc": "ISO-8601 UTC instant the SLA is due." }
  ]
}
