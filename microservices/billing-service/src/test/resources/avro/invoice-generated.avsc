{
  "type": "record",
  "name": "InvoiceGeneratedEvent",
  "namespace": "com.telco.platform.events.invoice",
  "doc": "Frozen contract snapshot for invoice.generated.v1 (ADR-019). Producer: billing-service; consumers: notification, payment. Field names must match the InvoiceGeneratedEvent outbox payload emitted by RunBillCommandHandler; the schema-compat test fails the build on any drift (NFR-16).",
  "fields": [
    { "name": "invoiceId", "type": "string", "doc": "Unique invoice identifier (UUID)." },
    { "name": "customerId", "type": "string", "doc": "Identifier of the billed customer (UUID)." },
    { "name": "subscriptionId", "type": "string", "doc": "Subscription the invoice covers (UUID)." },
    {
      "name": "periodStart",
      "type": { "type": "long", "logicalType": "timestamp-millis" },
      "doc": "Start of the billed period, in epoch milliseconds (UTC)."
    },
    {
      "name": "periodEnd",
      "type": { "type": "long", "logicalType": "timestamp-millis" },
      "doc": "End of the billed period, in epoch milliseconds (UTC)."
    },
    {
      "name": "grandTotal",
      "type": { "type": "bytes", "logicalType": "decimal", "precision": 19, "scale": 4 },
      "doc": "Invoice grand total as an exact decimal. Always paired with currency."
    },
    { "name": "currency", "type": "string", "doc": "ISO 4217 currency code, for example TRY." },
    {
      "name": "issuedAt",
      "type": { "type": "long", "logicalType": "timestamp-millis" },
      "doc": "Instant the invoice was issued, in epoch milliseconds (UTC)."
    }
  ]
}
