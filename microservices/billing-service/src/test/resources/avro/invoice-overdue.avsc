{
  "type": "record",
  "name": "InvoiceOverdueEvent",
  "namespace": "com.telco.platform.events.invoice",
  "doc": "Frozen contract snapshot for invoice.overdue.v1 (ADR-019). Producer: billing-service; consumers: notification, ticket. Field names must match the InvoiceOverdueEvent outbox payload emitted by MarkInvoicesOverdueCommandHandler; the schema-compat test fails the build on any drift (NFR-16).",
  "fields": [
    { "name": "invoiceId", "type": "string", "doc": "Unique invoice identifier (UUID)." },
    { "name": "customerId", "type": "string", "doc": "Identifier of the billed customer (UUID)." },
    { "name": "dueDate", "type": "string", "doc": "ISO-8601 date the invoice was due." },
    {
      "name": "detectedAt",
      "type": { "type": "long", "logicalType": "timestamp-millis" },
      "doc": "Instant the overdue state was detected, in epoch milliseconds (UTC)."
    }
  ]
}
