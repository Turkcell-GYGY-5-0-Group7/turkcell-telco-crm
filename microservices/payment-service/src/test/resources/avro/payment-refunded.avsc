{
  "type": "record",
  "name": "PaymentRefundedEvent",
  "namespace": "com.telco.platform.events.payment",
  "doc": "Frozen contract snapshot for payment.refunded.v1 (ADR-019). Producer: payment-service. Field names must match the com.telco.payment.application.event.PaymentRefundedEvent outbox payload record; the schema-compat test fails the build on any drift (NFR-16).",
  "fields": [
    { "name": "paymentId", "type": "string", "doc": "Unique payment identifier (UUID)." },
    { "name": "orderId", "type": "string", "doc": "Order this refund compensates (UUID)." },
    { "name": "customerId", "type": "string", "doc": "Identifier of the refunded customer (UUID)." },
    {
      "name": "amount",
      "type": { "type": "bytes", "logicalType": "decimal", "precision": 19, "scale": 4 },
      "doc": "Refunded amount as an exact decimal."
    },
    { "name": "reason", "type": "string", "doc": "Refund reason (compensation trigger)." },
    { "name": "occurredAt", "type": "string", "doc": "ISO-8601 UTC instant the refund was issued." }
  ]
}
