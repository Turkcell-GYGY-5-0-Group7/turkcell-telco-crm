{
  "type": "record",
  "name": "PaymentFailedEvent",
  "namespace": "com.telco.platform.events.payment",
  "doc": "Frozen contract snapshot for payment.failed.v1 (ADR-019). Producer: payment-service. Field names must match the com.telco.payment.application.event.PaymentFailedEvent outbox payload record; the schema-compat test fails the build on any drift (NFR-16).",
  "fields": [
    { "name": "paymentId", "type": "string", "doc": "Unique payment identifier (UUID)." },
    { "name": "orderId", "type": "string", "doc": "Order this payment attempt targets (UUID)." },
    { "name": "customerId", "type": "string", "doc": "Identifier of the paying customer (UUID)." },
    {
      "name": "amount",
      "type": { "type": "bytes", "logicalType": "decimal", "precision": 19, "scale": 4 },
      "doc": "Attempted amount as an exact decimal."
    },
    {
      "name": "invoiceId",
      "type": ["null", "string"],
      "default": null,
      "doc": "Invoice this payment attempt targets, when the payment originates from an invoice. Nullable for order-driven payments."
    },
    { "name": "reason", "type": "string", "doc": "Failure reason." },
    { "name": "occurredAt", "type": "string", "doc": "ISO-8601 UTC instant the payment failed." }
  ]
}
