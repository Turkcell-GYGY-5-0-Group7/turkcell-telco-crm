{
  "type": "record",
  "name": "PaymentCompletedEvent",
  "namespace": "com.telco.platform.events.payment",
  "doc": "Frozen contract snapshot for payment.completed.v1 (ADR-019). Producer: payment-service. Field names must match the com.telco.payment.application.event.PaymentCompletedEvent outbox payload record; the schema-compat test fails the build on any drift (NFR-16).",
  "fields": [
    { "name": "paymentId", "type": "string", "doc": "Unique payment identifier (UUID)." },
    { "name": "orderId", "type": "string", "doc": "Order this payment settles (UUID)." },
    { "name": "customerId", "type": "string", "doc": "Identifier of the paying customer (UUID)." },
    {
      "name": "amount",
      "type": { "type": "bytes", "logicalType": "decimal", "precision": 19, "scale": 4 },
      "doc": "Paid amount as an exact decimal. Always paired with the order currency."
    },
    { "name": "occurredAt", "type": "string", "doc": "ISO-8601 UTC instant the payment completed." }
  ]
}
