<?xml version="1.0" encoding="UTF-8"?>
<!--
  reference-service structured logging (ADR-012, ADR-021).

  This file overrides the platform starter's logback-spring.xml for the reference-service.
  It mirrors the platform standard: structured JSON via LogstashEncoder, Loki4j shipping,
  PII masking converters registered for any pattern-based appender added in future.

  Trace context: CorrelationFilter writes traceId, spanId (from Micrometer Tracing OTel bridge),
  and correlationId to MDC.  LogstashEncoder emits the full MDC map as JSON fields automatically.

  PII masking: Layer A (@Sensitive ObjectMapper) covers structured domain output.  The %mask and
  %maskEx converters (Layer B, ADR-021) are registered below for pattern-based appenders; they are
  not applied by LogstashEncoder which uses its own serialization chain.
-->
<configuration>

    <conversionRule conversionWord="mask"
                    class="com.telco.platform.starter.observability.logging.PiiMaskingConverter"/>
    <conversionRule conversionWord="maskEx"
                    class="com.telco.platform.starter.observability.logging.PiiMaskingThrowableConverter"/>

    <springProperty scope="context" name="appName"
                    source="spring.application.name" defaultValue="reference-service"/>
    <springProperty scope="context" name="lokiUrl"
                    source="loki.url" defaultValue="http://localhost:3100/loki/api/v1/push"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>false</includeContext>
        </encoder>
    </appender>

    <springProfile name="!test">

        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <batchMaxItems>100</batchMaxItems>
            <batchTimeoutMs>4000</batchTimeoutMs>
            <http>
                <url>${lokiUrl}</url>
            </http>
            <format>
                <label>
                    <pattern>job=telco-crm,service=${appName}</pattern>
                </label>
                <message>
                    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                        <includeContext>false</includeContext>
                    </encoder>
                </message>
            </format>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="LOKI"/>
        </root>

        <logger name="com.telco" level="DEBUG"/>

    </springProfile>

    <springProfile name="test">

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.telco" level="DEBUG"/>

    </springProfile>

</configuration>
