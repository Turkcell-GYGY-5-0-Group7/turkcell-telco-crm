{
  "type": "record",
  "name": "TariffCreatedEvent",
  "namespace": "com.telco.platform.events.tariff",
  "doc": "Frozen contract snapshot for tariff.created.v1 (ADR-019). Producer: product-catalog-service. Field names must match the com.telco.catalog.domain.event.TariffCreatedEvent outbox payload record; the schema-compat test fails the build on any drift (NFR-16).",
  "fields": [
    { "name": "tariffId", "type": "string", "doc": "Unique tariff identifier (UUID)." },
    { "name": "code", "type": "string", "doc": "Business code of the tariff." },
    { "name": "name", "type": "string", "doc": "Display name of the tariff." },
    { "name": "type", "type": "string", "doc": "Tariff type enum name." },
    {
      "name": "monthlyFee",
      "type": { "type": "bytes", "logicalType": "decimal", "precision": 19, "scale": 4 },
      "doc": "Recurring monthly fee as an exact decimal. Always paired with currency."
    },
    { "name": "currency", "type": "string", "doc": "ISO 4217 currency code, for example TRY." },
    { "name": "effectiveFrom", "type": "string", "doc": "ISO-8601 UTC instant the tariff becomes effective." },
    { "name": "createdAt", "type": "string", "doc": "ISO-8601 UTC instant the tariff was created." }
  ]
}
