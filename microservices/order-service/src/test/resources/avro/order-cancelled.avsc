{
  "type": "record",
  "name": "OrderCancelledEvent",
  "namespace": "com.telco.platform.events.order",
  "doc": "Frozen contract snapshot for order.cancelled.v1 (ADR-019). Producer: order-service. Field names must match the com.telco.order.application.event.OrderCancelledEvent outbox payload record; the schema-compat test fails the build on any drift (NFR-16).",
  "fields": [
    { "name": "orderId", "type": "string", "doc": "Unique order identifier (UUID)." },
    { "name": "customerId", "type": "string", "doc": "Identifier of the owning customer." },
    { "name": "reason", "type": "string", "doc": "Cancellation reason (compensation trigger)." },
    { "name": "occurredAt", "type": "string", "doc": "ISO-8601 UTC instant the order was cancelled." }
  ]
}
