{
  "type": "record",
  "name": "OrderCreatedEvent",
  "namespace": "com.telco.platform.events.order",
  "doc": "Frozen contract snapshot for order.created.v1 (ADR-019). Producer: order-service. Field names must match the com.telco.order.application.event.OrderCreatedEvent outbox payload record; the schema-compat test fails the build on any drift (NFR-16).",
  "fields": [
    { "name": "orderId", "type": "string", "doc": "Unique order identifier (UUID)." },
    { "name": "customerId", "type": "string", "doc": "Identifier of the customer who placed the order." },
    {
      "name": "items",
      "type": { "type": "array", "items": "OrderItemPayload" },
      "doc": "Line items with their tariff snapshot. See order-item.avsc for the element contract."
    },
    {
      "name": "totalAmount",
      "type": { "type": "bytes", "logicalType": "decimal", "precision": 19, "scale": 4 },
      "doc": "Order total as an exact decimal. Always paired with the order currency."
    },
    { "name": "idempotencyKey", "type": "string", "doc": "Client idempotency key for the order command." },
    { "name": "occurredAt", "type": "string", "doc": "ISO-8601 UTC instant the order was created." }
  ]
}
