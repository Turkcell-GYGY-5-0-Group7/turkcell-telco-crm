{
  "type": "record",
  "name": "OrderItemPayload",
  "namespace": "com.telco.platform.events.order",
  "doc": "Frozen contract snapshot for the item element embedded in order.created.v1 (ADR-019). Field names must match the com.telco.order.application.event.OrderCreatedEvent.OrderItemPayload nested record.",
  "fields": [
    { "name": "tariffId", "type": "string", "doc": "Tariff identifier for the line (UUID)." },
    { "name": "tariffName", "type": "string", "doc": "Tariff display name snapshot." },
    {
      "name": "unitPrice",
      "type": { "type": "bytes", "logicalType": "decimal", "precision": 19, "scale": 4 },
      "doc": "Unit price as an exact decimal."
    },
    { "name": "quantity", "type": "int", "doc": "Quantity ordered for the line." }
  ]
}
