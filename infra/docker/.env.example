# ---------------------------------------------------------------------------
# Telco CRM local infrastructure - environment template
# Copy to `.env` (which is gitignored) and adjust as needed:
#   cp .env.example .env
# All image tags and local credentials live here so they are easy to change.
# These credentials are for LOCAL development only. Never reuse in any shared env.
# ---------------------------------------------------------------------------

COMPOSE_PROJECT_NAME=telco-crm

# --- Image versions (ADR-003) ---------------------------------------------
POSTGRES_VERSION=17
REDIS_VERSION=8
KAFKA_VERSION=4.0.0
SCHEMA_REGISTRY_VERSION=7.9.0
DEBEZIUM_CONNECT_VERSION=3.1.0.Final
KAFKA_UI_VERSION=latest
KEYCLOAK_VERSION=26.1
PROMETHEUS_VERSION=v3.0.1
GRAFANA_VERSION=11.4.0
LOKI_VERSION=3.3.1
TEMPO_VERSION=2.6.1
OTEL_COLLECTOR_VERSION=0.119.0

# --- PostgreSQL -----------------------------------------------------------
POSTGRES_USER=telco
POSTGRES_PASSWORD=telco
POSTGRES_PORT=5432

# --- Redis ----------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=telco

# --- Kafka ----------------------------------------------------------------
# 29092 is the host-facing listener; in-cluster services use kafka:9092.
KAFKA_HOST_PORT=29092
SCHEMA_REGISTRY_PORT=8081
KAFKA_CONNECT_PORT=8083
KAFKA_UI_PORT=8088

# --- Keycloak (auth profile) ----------------------------------------------
KEYCLOAK_PORT=8085
KEYCLOAK_MANAGEMENT_PORT=8086
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Observability (observability profile) --------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
LOKI_PORT=3100
TEMPO_PORT=3200
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
