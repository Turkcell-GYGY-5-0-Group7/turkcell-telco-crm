# ---------------------------------------------------------------------------
# Telco CRM local infrastructure - environment template
# Copy to `.env` (which is gitignored) and adjust as needed:
#   cp .env.example .env
# All image tags and local credentials live here so they are easy to change.
# These credentials are for LOCAL development only. Never reuse in any shared env.
# ---------------------------------------------------------------------------

COMPOSE_PROJECT_NAME=telco-crm

# --- Image versions (ADR-003) ---------------------------------------------
POSTGRES_VERSION=17
REDIS_VERSION=8
KAFKA_VERSION=4.0.0
SCHEMA_REGISTRY_VERSION=7.9.0
DEBEZIUM_CONNECT_VERSION=3.1.0.Final
KAFKA_UI_VERSION=latest
KEYCLOAK_VERSION=26.1
PROMETHEUS_VERSION=v3.0.1
GRAFANA_VERSION=11.4.0
LOKI_VERSION=3.3.1
TEMPO_VERSION=2.6.1
OTEL_COLLECTOR_VERSION=0.119.0
MINIO_VERSION=RELEASE.2025-04-08T15-41-24Z
MINIO_MC_VERSION=RELEASE.2025-04-08T15-39-49Z
MONGO_VERSION=7

# --- PostgreSQL -----------------------------------------------------------
POSTGRES_USER=telco
POSTGRES_PASSWORD=telco
POSTGRES_PORT=5432

# --- Redis ----------------------------------------------------------------
REDIS_PORT=6379
REDIS_PASSWORD=telco

# --- MongoDB (notification-service document store, ADR-006) ----------------
# No auth configured for local dev: matches the unauthenticated
# mongodb://mongo:27017/notification_db URI in every notification-service profile.
MONGO_PORT=27017

# --- Kafka ----------------------------------------------------------------
# 29092 is the host-facing listener; in-cluster services use kafka:9092.
KAFKA_HOST_PORT=29092
SCHEMA_REGISTRY_PORT=8081
KAFKA_CONNECT_PORT=8083
KAFKA_UI_PORT=8088

# --- Keycloak (auth profile) ----------------------------------------------
KEYCLOAK_PORT=8085
KEYCLOAK_MANAGEMENT_PORT=8086
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Dedicated Keycloak DB user (not the superuser — see tech-lead ruling 2026-06-26).
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak

# --- Debezium CDC ---------------------------------------------------------
# Dedicated replication user; has REPLICATION privilege + SELECT on each service DB.
# Never use the superuser (telco) for CDC connectors.
DEBEZIUM_DB_USER=debezium
DEBEZIUM_DB_PASSWORD=debezium

# --- Spring Boot platform services (platform profile) --------------------
# ENCRYPT_KEY is required by config-server (AES-256 key for encrypted properties).
# Generate a fresh key per environment:  openssl rand -hex 32
# NEVER commit a real key. Replace the placeholder below in your .env.
ENCRYPT_KEY=replace-me-run-openssl-rand-hex-32
CONFIG_SERVER_PORT=8888
CONFIG_SERVER_USER=config
CONFIG_SERVER_PASSWORD=config
EUREKA_PORT=8761
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=eureka
GATEWAY_PORT=8080
# Keycloak JWKS URI for the gateway JWT validator (used with --profile auth).
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/telco-crm/protocol/openid-connect/certs

# --- Domain services (apps profile) ---------------------------------------
# Host port mappings for the 10 domain services; container ports are fixed.
IDENTITY_SERVICE_PORT=9001
CUSTOMER_SERVICE_PORT=9002
PRODUCT_CATALOG_SERVICE_PORT=9003
ORDER_SERVICE_PORT=9004
SUBSCRIPTION_SERVICE_PORT=9005
USAGE_SERVICE_PORT=9006
BILLING_SERVICE_PORT=9007
PAYMENT_SERVICE_PORT=9008
NOTIFICATION_SERVICE_PORT=9009
TICKET_SERVICE_PORT=9010

# Deterministic override for payment-service's MockPspAdapter (normally ~10% random charge
# failure, no fast retry path). Leave unset for local dev to keep exercising the failure/retry
# path; the CI acceptance workflow sets this to SUCCESS so saga-completion polling isn't racing
# a simulated payment failure. Values: SUCCESS, FAILURE, or unset for random.
#PSP_MOCK_FORCE_OUTCOME=

# --- Observability (observability profile) --------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
LOKI_PORT=3100
TEMPO_PORT=3200
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# --- MinIO (object store, KYC documents - Sprint 06, ADR-006) --------------
# S3 API stays on 9000 (customer-service expects it). Console on 9090 to avoid
# clashing with identity-service (9001). LOCAL credentials only.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9090
