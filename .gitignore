# ---------------------------------------------------------------------------
# Telco CRM Platform - .gitignore
# ---------------------------------------------------------------------------

# --- Build output ---------------------------------------------------------
target/
build/
out/
bin/
dist/
generated-sources/
generated-test-sources/
*.class
*.jar
*.war
*.ear
*.nar
!.mvn/wrapper/maven-wrapper.jar
!**/src/**/*.jar

# --- Maven ----------------------------------------------------------------
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.properties
release.properties
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
dependency-reduced-pom.xml
buildNumber.properties

# --- Gradle (in case a module uses it) ------------------------------------
.gradle/

# --- Secrets and local configuration (NEVER commit) -----------------------
*.env
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
*.keystore
*.truststore
secrets.*
**/application-local.yml
**/application-local.yaml
**/application-local.properties
**/application-secret*.yml
**/application-secret*.yaml
**/application-secret*.properties
**/*-credentials.json
kubeconfig
*.kubeconfig

# --- Logs and temporary files ---------------------------------------------
*.log
logs/
*.tmp
*.bak
*.swp
*.pid
hs_err_pid*
replay_pid*

# --- IDEs and editors -----------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.code-workspace
.settings/
.project
.classpath
.factorypath
.apt_generated/
*.sublime-project
*.sublime-workspace
nb-configuration.xml

# --- OS files -------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Containers and infrastructure ----------------------------------------
docker-compose.override.yml
*.local.yml

# --- Test, coverage, and analysis output ----------------------------------
*.exec
.jacoco/
jacoco.exec
surefire-reports/
failsafe-reports/
.sonar/
.scannerwork/

# --- Node (only if frontend tooling is added later) -----------------------
node_modules/
npm-debug.log*
yarn-error.log*
site/
