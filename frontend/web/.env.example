# Telco CRM web frontend configuration (ADR-022).
# Copy to `.env` for local overrides. Only PUBLIC_-prefixed vars are exposed to
# the browser bundle (SvelteKit $env/dynamic/public).

# Outbound base URL for the typed BFF API client (src/lib/api/client.ts).
# The browser targets the BFF surface `/bff/v1/**`; per ADR-022's thin-slice
# allowance it MAY reach the API gateway directly until the web-bff composes an
# endpoint. It must NEVER point at a domain-service host/port (ADR-011 Sec 2).
# Dev default when unset: http://localhost:8080 (the local gateway origin).
# In production, prefer a same-origin value such as `/`.
PUBLIC_BFF_BASE_URL=http://localhost:8080

# Keycloak Authorization Code + PKCE login (ADR-011 / ADR-022, subtask 16.3.1).
# The BROWSER performs PKCE directly against the `telco-web` PUBLIC client - no
# client secret is ever set here. All values are optional; the dev defaults
# below match the local realm and the `telco-web` redirect URI
# `http://localhost:3000/*`.
#
# Browser-facing Keycloak realm authority (OIDC discovery base). Locally Keycloak
# is exposed on host port 8085 (infra/docker/compose.yml). Default when unset:
# http://localhost:8085/realms/telco-crm
PUBLIC_OIDC_AUTHORITY=http://localhost:8085/realms/telco-crm
# Public SPA client id. Default when unset: telco-web
PUBLIC_OIDC_CLIENT_ID=telco-web
# OIDC redirect + post-logout URIs. Defaults derive from the browser origin:
# http://localhost:3000/auth/callback and http://localhost:3000/login
PUBLIC_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
PUBLIC_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/login
